<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- assign is_pro = false -%}
{%- for tag in customer.tags -%}
  {%- if tag == 'pro' or tag == 'PRO' or tag == 'Pro' -%}
    {%- assign is_pro = true -%}
  {%- endif -%}
{%- endfor -%}
{%- assign initiales = customer.first_name | slice: 0 -%}
{%- assign initiales2 = customer.last_name | slice: 0 -%}
{%- assign orders_count = customer.orders_count -%}
{%- assign total_spent = customer.total_spent | money_without_trailing_zeros -%}
{%- assign pending_count = 0 -%}
{%- for order in customer.orders -%}
  {%- if order.fulfillment_status == 'unfulfilled' or order.fulfillment_status == 'partial' -%}
    {%- assign pending_count = pending_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

<style>
:root{--bg:#0a0f1a;--surface:#111827;--surface2:#1a2235;--border:#1e2d45;--accent2:#00ff9d;--gold:#f5c842;--red:#ff4757;--text:#ffffff;--dim:#a0aec0;}
*{box-sizing:border-box;}
.fl-acc-wrap{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif;min-height:60vh;}
.acc-hero{background:linear-gradient(135deg,#0d1a2e 0%,#0a1520 60%,#0d1a2e 100%);border-bottom:2px solid var(--border);padding:28px 24px;display:flex;align-items:center;gap:20px;position:relative;overflow:hidden;flex-wrap:wrap;}
.fl-avatar{width:72px;height:72px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,#2a4a8a,#0050ff);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;color:#fff;border:2px solid rgba(255,255,255,0.2);font-family:'Bebas Neue',sans-serif;}
.fl-avatar.pro{background:linear-gradient(135deg,var(--gold),#ff8c00);border-color:rgba(245,200,66,0.5);}
.acc-hero-info{flex:1;min-width:180px;}
.acc-hero-info h2{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:3px;margin:0;color:#fff !important;}
.acc-hero-info p{color:#cbd5e0;font-size:14px;margin-top:4px;}
.hero-actions{display:flex;gap:10px;margin-top:12px;flex-wrap:wrap;align-items:center;}
.acc-badge{padding:6px 16px;border-radius:50px;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;white-space:nowrap;align-self:flex-start;}
.badge-part{background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.3);}
.badge-pro{background:rgba(245,200,66,0.15);color:var(--gold);border:1px solid rgba(245,200,66,0.4);}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border-bottom:1px solid var(--border);}
.stat-card{background:var(--surface);padding:24px 12px;text-align:center;}
.stat-card .val{font-family:'Bebas Neue',sans-serif;font-size:44px;color:#fff;line-height:1;}
.stat-card .val.gold{color:var(--gold);}
.stat-card .lbl{font-size:12px;color:var(--dim);letter-spacing:2px;text-transform:uppercase;margin-top:6px;font-weight:600;}
.acc-tabs{display:flex;background:var(--surface);border-bottom:2px solid var(--border);padding:0 20px;overflow-x:auto;scrollbar-width:none;}
.acc-tabs::-webkit-scrollbar{display:none;}
.tab-btn{padding:18px 22px;font-size:14px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim);cursor:pointer;border:none;background:none;border-bottom:3px solid transparent;white-space:nowrap;transition:all .2s;display:flex;align-items:center;gap:8px;font-family:'Outfit',sans-serif;}
.tab-btn:hover{color:#fff;}
.tab-btn.active{color:#fff;border-bottom-color:#fff;}
.tab-btn.active.pro-tab{color:var(--gold);border-bottom-color:var(--gold);}
.tab-badge{background:#fff;color:#000;font-size:10px;font-weight:700;padding:2px 6px;border-radius:10px;}
.acc-body{display:grid;grid-template-columns:1fr 300px;gap:20px;padding:24px;max-width:1400px;margin:0 auto;}
.tab-panel{display:none;}
.tab-panel.active{display:block;}
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:2px;color:#fff;margin-bottom:14px;display:flex;align-items:center;gap:10px;}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border);}
.order-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;margin-bottom:12px;overflow:hidden;}
.order-card:hover{border-color:rgba(255,255,255,0.2);}
.order-head{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:8px;}
.order-num{font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:2px;color:#fff;}
.order-num.gold{color:var(--gold);}
.order-date{font-size:12px;color:var(--dim);margin-top:2px;}
.order-status{padding:4px 10px;border-radius:50px;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.s-delivered{background:rgba(0,255,157,0.12);color:var(--accent2);border:1px solid rgba(0,255,157,0.3);}
.s-shipping{background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.3);}
.s-pending{background:rgba(245,200,66,0.12);color:var(--gold);border:1px solid rgba(245,200,66,0.3);}
.s-cancelled{background:rgba(255,71,87,0.12);color:var(--red);border:1px solid rgba(255,71,87,0.3);}
.order-body{display:flex;align-items:center;padding:14px 18px;gap:14px;flex-wrap:wrap;}
.order-items{display:flex;gap:6px;flex-wrap:wrap;flex:1;min-width:120px;}
.order-item-img{width:48px;height:48px;border-radius:6px;object-fit:cover;border:1px solid var(--border);background:var(--surface2);}
.order-detail{flex:1;min-width:120px;}
.order-detail .oname{font-size:13px;font-weight:600;margin-bottom:3px;color:#fff;}
.order-detail .odesc{font-size:11px;color:var(--dim);}
.order-price{font-family:'Bebas Neue',sans-serif;font-size:24px;color:#fff;white-space:nowrap;}
.order-price.gold{color:var(--gold);}
.order-actions{display:flex;gap:8px;padding:10px 18px;border-top:1px solid var(--border);background:rgba(0,0,0,0.2);flex-wrap:wrap;}
.btn-fl{padding:7px 14px;border-radius:6px;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border:1px solid rgba(255,255,255,0.2);background:transparent;color:#fff;font-family:'Outfit',sans-serif;transition:all .2s;text-decoration:none;display:inline-flex;align-items:center;gap:4px;}
.btn-fl:hover{border-color:#fff;background:rgba(255,255,255,0.08);}
.btn-fl.primary{background:#fff;border-color:#fff;color:#000;}
.btn-fl.primary:hover{opacity:.85;}
.btn-fl.gold{background:var(--gold);border-color:var(--gold);color:#000;}
.btn-fl.danger{border-color:rgba(255,71,87,0.4);color:var(--red);}
.btn-fl.danger:hover{background:rgba(255,71,87,0.12);}
.btn-fl.disabled{opacity:.35;cursor:not-allowed;pointer-events:none;}
.sidebar{display:flex;flex-direction:column;gap:14px;}
.side-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;}
.side-card.gold-border{border-color:rgba(245,200,66,0.25);}
.sc-head{padding:12px 16px;border-bottom:1px solid var(--border);font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#fff;display:flex;justify-content:space-between;align-items:center;}
.sc-head.gold{color:var(--gold);}
.sc-body{padding:16px;}
.info-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);font-size:13px;}
.info-row:last-child{border-bottom:none;}
.info-row .lbl{color:var(--dim);}
.info-row .val{font-weight:600;color:#fff;}
.addr-tag{display:inline-block;padding:2px 7px;background:rgba(255,255,255,0.1);color:#fff;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;}
.addr-tag.gold{background:rgba(245,200,66,0.1);color:var(--gold);}
.addr-line{font-size:13px;line-height:1.9;color:#fff;}
.pro-ribbon{background:linear-gradient(90deg,rgba(245,200,66,0.12),transparent);border-left:3px solid var(--gold);padding:12px 16px;border-radius:0 8px 8px 0;margin-bottom:16px;font-size:13px;color:rgba(245,200,66,0.85);}
.pro-ribbon strong{display:block;font-size:14px;color:var(--gold);margin-bottom:3px;}
.invoice-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border);gap:8px;flex-wrap:wrap;}
.invoice-row:last-child{border-bottom:none;}
.inv-ref{font-family:'Bebas Neue',sans-serif;letter-spacing:1px;color:var(--gold);font-size:15px;}
.inv-date{font-size:12px;color:var(--dim);}
.inv-amount{font-weight:700;font-size:14px;white-space:nowrap;color:#fff;}
.inv-status{font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px;white-space:nowrap;}
.inv-status.paid{background:rgba(0,255,157,0.12);color:var(--accent2);border:1px solid rgba(0,255,157,0.3);}
.inv-status.pending{background:rgba(245,200,66,0.12);color:var(--gold);border:1px solid rgba(245,200,66,0.3);}
.inv-status.scheduled{background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.3);}
.inv-status.error{background:rgba(255,71,87,0.12);color:var(--red);border:1px solid rgba(255,71,87,0.3);}
.inv-items{font-size:11px;color:var(--dim);margin-top:2px;}
.btn-pdf{padding:6px 12px;background:var(--gold);border:none;color:#000;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Outfit',sans-serif;white-space:nowrap;letter-spacing:1px;text-transform:uppercase;}
.btn-pdf:hover{opacity:.85;}
.inv-loading{text-align:center;padding:30px;color:var(--dim);font-size:13px;}
.inv-loading .spinner{display:inline-block;width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin .8s linear infinite;margin-bottom:10px;}
@keyframes spin{to{transform:rotate(360deg);}}
.logout-btn{display:inline-flex;align-items:center;gap:5px;color:var(--red);font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;text-decoration:none;opacity:.7;}
.logout-btn:hover{opacity:1;}
.empty-state{text-align:center;padding:48px 24px;color:var(--dim);}
.empty-state .icon{font-size:48px;margin-bottom:16px;opacity:.5;display:block;}
.empty-state p{font-size:14px;}
.fl-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:9999;align-items:center;justify-content:center;padding:20px;}
.fl-modal-overlay.open{display:flex;}
.fl-modal{background:var(--surface);border:1px solid var(--border);border-radius:14px;width:100%;max-width:480px;overflow:hidden;animation:modalIn .3s cubic-bezier(.22,1,.36,1);}
@keyframes modalIn{from{opacity:0;transform:translateY(-24px) scale(.95);}to{opacity:1;transform:none;}}
.fl-modal-topbar{height:3px;background:linear-gradient(90deg,#fff,#00ff9d 50%,#f5c842);}
.fl-modal-topbar.red{background:linear-gradient(90deg,#ff4757,#ff9f43);}
.fl-modal-head{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.fl-modal-head h3{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;color:#fff;margin:0;}
.fl-modal-head h3.gold{color:var(--gold);}
.fl-modal-close{background:none;border:none;color:var(--dim);font-size:20px;cursor:pointer;line-height:1;}
.fl-modal-close:hover{color:var(--red);}
.fl-modal-body{padding:22px 20px;}
.fm-field{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
.fm-field label{font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim);}
.fm-field input{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px 14px;color:#fff;font-family:'Outfit',sans-serif;font-size:14px;outline:none;width:100%;}
.fm-field input:focus{border-color:rgba(255,255,255,0.5);}
.fm-field input::placeholder{color:var(--dim);}
.fm-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.fm-btn{width:100%;padding:13px;border-radius:8px;border:none;cursor:pointer;font-family:'Outfit',sans-serif;font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;background:#fff;color:#000;margin-top:4px;}
.fm-btn:hover{opacity:.85;}
.fm-btn.gold-btn{background:linear-gradient(135deg,var(--gold),#ff8c00);color:#000;}
.fm-note{font-size:12px;color:var(--dim);text-align:center;margin-top:12px;line-height:1.6;}
.fm-success{display:none;text-align:center;padding:10px 0;}
.fm-success .fs-icon{font-size:56px;margin-bottom:14px;display:block;}
.fm-success h4{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:2px;color:var(--accent2);margin:0 0 10px;}
.fm-success p{font-size:13px;color:var(--dim);line-height:1.7;}
@media(max-width:900px){.acc-body{grid-template-columns:1fr;}.sidebar{order:2;}}
@media(max-width:600px){.stats-row{grid-template-columns:repeat(2,1fr);}.acc-hero{padding:18px 16px;gap:14px;}.acc-badge{display:none;}.fl-avatar{width:52px;height:52px;font-size:18px;}.acc-hero-info h2{font-size:24px;}.acc-body{padding:14px;}.btn-fl{padding:5px 9px;font-size:10px;}.acc-tabs{padding:0 10px;}.tab-btn{padding:14px 12px;font-size:12px;}.stat-card .val{font-size:34px;}.fm-row{grid-template-columns:1fr;}}
</style>

<!-- MODAL MODIFIER -->
<div class="fl-modal-overlay" id="modalEdit">
  <div class="fl-modal">
    <div class="fl-modal-topbar"></div>
    <div class="fl-modal-head">
      <h3 {% if is_pro %}class="gold"{% endif %}>✏️ Modifier mes informations</h3>
      <button class="fl-modal-close" onclick="flCloseModal('modalEdit')">✕</button>
    </div>
    <div class="fl-modal-body">
      {% form 'customer' %}
        {{ form.errors | default_errors }}
        <div class="fm-row">
          <div class="fm-field"><label>Prénom</label><input type="text" name="customer[first_name]" value="{{ customer.first_name }}" required></div>
          <div class="fm-field"><label>Nom</label><input type="text" name="customer[last_name]" value="{{ customer.last_name }}" required></div>
        </div>
        <div class="fm-field"><label>Email</label><input type="email" name="customer[email]" value="{{ customer.email }}" required></div>
        <div class="fm-field"><label>Téléphone</label><input type="tel" name="customer[phone]" value="{{ customer.phone }}"></div>
        <button type="submit" class="fm-btn {% if is_pro %}gold-btn{% endif %}">💾 Enregistrer</button>
        <p class="fm-note">Pour changer le mot de passe, utilisez le bouton "🔑 Mot de passe".</p>
      {% endform %}
    </div>
  </div>
</div>

<!-- MODAL MOT DE PASSE -->
{% form 'recover_customer_password' %}
  {% assign recover_posted = form.posted_successfully? %}
  {% assign recover_error_count = form.errors.count %}
{% endform %}

<div class="fl-modal-overlay" id="modalPwd">
  <div class="fl-modal">
    <div class="fl-modal-topbar red"></div>
    <div class="fl-modal-head">
      <h3>🔑 Réinitialiser le mot de passe</h3>
      <button class="fl-modal-close" onclick="flCloseModal('modalPwd')">✕</button>
    </div>
    <div class="fl-modal-body">
      <div id="pwdFormWrap">
        {% form 'recover_customer_password' %}
          {% if form.errors %}<div style="background:rgba(255,71,87,0.08);border:1px solid rgba(255,71,87,0.3);border-radius:8px;padding:12px;color:var(--red);font-size:13px;margin-bottom:16px;">{{ form.errors | default_errors }}</div>{% endif %}
          <p style="font-size:13px;color:var(--dim);margin-bottom:20px;line-height:1.7;">Entrez votre adresse e-mail pour recevoir un lien de réinitialisation.</p>
          <div class="fm-field"><label>Adresse e-mail</label><input type="email" name="email" value="{{ customer.email }}" required></div>
          <button type="submit" class="fm-btn" style="background:linear-gradient(135deg,#ff4757,#ff9f43);color:#fff;">📨 Envoyer le lien</button>
        {% endform %}
        <button onclick="flCloseModal('modalPwd')" style="width:100%;margin-top:10px;padding:10px;background:none;border:1px solid var(--border);color:var(--dim);border-radius:8px;cursor:pointer;font-family:'Outfit',sans-serif;font-size:12px;letter-spacing:1px;text-transform:uppercase;">← Annuler</button>
      </div>
      <div class="fm-success" id="pwdSuccess">
        <span class="fs-icon">✅</span>
        <h4>E-mail envoyé !</h4>
        <p>Vérifiez votre boîte mail et vos spams.</p>
        <button onclick="flCloseModal('modalPwd')" class="fm-btn" style="margin-top:20px;max-width:200px;margin-left:auto;margin-right:auto;display:block;">Fermer</button>
      </div>
    </div>
  </div>
</div>

<!-- PAGE PRINCIPALE -->
<div class="fl-acc-wrap">

  <!-- HERO -->
  <div class="acc-hero {% if is_pro %}pro{% endif %}">
    <div class="fl-avatar {% if is_pro %}pro{% endif %}">{{ initiales }}{{ initiales2 }}</div>
    <div class="acc-hero-info">
      <h2>{{ customer.first_name }} {{ customer.last_name }}</h2>
      <p>{{ customer.email }}{% if customer.created_at %} · Membre depuis {{ customer.created_at | date: "%B %Y" }}{% endif %}</p>
      <div class="hero-actions">
        <button class="btn-fl" onclick="flOpenModal('modalEdit')">✏️ Modifier</button>
        <button class="btn-fl" onclick="flOpenModal('modalPwd')">🔑 Mot de passe</button>
        <a href="{{ routes.account_logout_url }}" class="logout-btn">⏻ Déconnexion</a>
      </div>
    </div>
    <div class="acc-badge {% if is_pro %}badge-pro{% else %}badge-part{% endif %}">{% if is_pro %}⭐ Client PRO{% else %}👤 Particulier{% endif %}</div>
  </div>

  <!-- STATS -->
  <div class="stats-row">
    <div class="stat-card"><div class="val {% if is_pro %}gold{% endif %}">{{ orders_count }}</div><div class="lbl">Commandes</div></div>
    <div class="stat-card"><div class="val {% if is_pro %}gold{% endif %}">{{ total_spent }}</div><div class="lbl">{% if is_pro %}CA total HT{% else %}Total dépensé{% endif %}</div></div>
    <div class="stat-card"><div class="val {% if is_pro %}gold{% endif %}">{{ pending_count }}</div><div class="lbl">En cours</div></div>
    <div class="stat-card"><div class="val {% if is_pro %}gold{% endif %}">{% if is_pro %}⭐{% else %}{{ customer.addresses_count }}{% endif %}</div><div class="lbl">{% if is_pro %}Statut PRO{% else %}Adresses{% endif %}</div></div>
  </div>

  <!-- TABS -->
  <div class="acc-tabs">
    {% if is_pro %}
      <button class="tab-btn pro-tab active" id="btn-invoices" onclick="flTab('invoices',this)">📋 Mes Commandes PRO</button>
      <button class="tab-btn pro-tab" id="btn-company" onclick="flTab('company',this)">🏢 Mon entreprise</button>
      <button class="tab-btn pro-tab" id="btn-addresses" onclick="flTab('addresses',this)">📍 Adresses</button>
      <button class="tab-btn pro-tab" id="btn-account" onclick="flTab('account',this)">⚙️ Mon compte</button>
    {% else %}
      <button class="tab-btn active" id="btn-orders" onclick="flTab('orders',this)">📦 Commandes{% if pending_count > 0 %}<span class="tab-badge">{{ pending_count }}</span>{% endif %}</button>
      <button class="tab-btn" id="btn-addresses" onclick="flTab('addresses',this)">📍 Adresses</button>
      <button class="tab-btn" id="btn-account" onclick="flTab('account',this)">⚙️ Mon compte</button>
    {% endif %}
  </div>

  <!-- BODY -->
  <div class="acc-body">
    <div class="acc-left">

      <!-- TAB COMMANDES (particuliers uniquement) -->
      {% unless is_pro %}
      <div class="tab-panel active" id="tab-orders">
        <div class="sec-title">Mes commandes</div>
        {% if customer.orders.size == 0 %}
          <div class="empty-state"><span class="icon">🎣</span><p>Vous n'avez pas encore passé de commande.</p><a href="/collections/all" class="btn-fl primary" style="margin-top:16px;display:inline-flex">Découvrir nos leurres</a></div>
        {% else %}
          {% for order in customer.orders %}
            {%- assign sc = 's-pending' -%}
            {%- assign sl = '⏳ En attente' -%}
            {%- assign has_tracking = false -%}
            {%- assign tracking_url = '' -%}
            {%- if order.fulfillment_status == 'fulfilled' -%}{%- assign sc = 's-delivered' -%}{%- assign sl = '✅ Livré' -%}
            {%- elsif order.fulfillment_status == 'partial' or order.fulfillment_status == 'unfulfilled' -%}
              {%- if order.financial_status == 'paid' -%}{%- assign sc = 's-shipping' -%}{%- assign sl = '🚚 En préparation' -%}{%- endif -%}
            {%- endif -%}
            {%- for f in order.fulfillments -%}
              {%- if f.tracking_number != blank -%}{%- assign has_tracking = true -%}{%- assign tracking_url = f.tracking_url -%}{%- assign sc = 's-shipping' -%}{%- assign sl = '🚚 En livraison' -%}{%- endif -%}
            {%- endfor -%}
            {%- if order.cancelled_at != blank -%}{%- assign sc = 's-cancelled' -%}{%- assign sl = '❌ Annulée' -%}{%- endif -%}
            <div class="order-card">
              <div class="order-head">
                <div><div class="order-num">{{ order.name }}</div><div class="order-date">{{ order.created_at | date: "%d %B %Y" }}</div></div>
                <div class="order-status {{ sc }}">{{ sl }}</div>
              </div>
              <div class="order-body">
                <div class="order-items">{% for li in order.line_items limit:3 %}{% if li.image %}<img src="{{ li.image | img_url: '80x80', crop: 'center' }}" alt="{{ li.title }}" class="order-item-img">{% endif %}{% endfor %}</div>
                <div class="order-detail">
                  <div class="oname">{% for li in order.line_items limit:2 %}{{ li.title }}{% unless forloop.last %} · {% endunless %}{% endfor %}{% if order.line_items.size > 2 %} + {{ order.line_items.size | minus: 2 }} autres{% endif %}</div>
                  <div class="odesc">{{ order.line_items.size }} article(s) · {{ order.created_at | date: "%d/%m/%Y" }}</div>
                </div>
                <div><div class="order-price">{{ order.total_price | money }}</div></div>
              </div>
              <div class="order-actions">
                <a href="{{ order.order_status_url }}" class="btn-fl primary">📄 Détails</a>
                {% if has_tracking %}<a href="{{ tracking_url }}" target="_blank" class="btn-fl">🚚 Suivre</a>{% else %}<span class="btn-fl disabled">🚚 Suivre</span>{% endif %}
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
      {% endunless %}

      <!-- TAB COMMANDES PRO -->
      {% if is_pro %}
      <div class="tab-panel active" id="tab-invoices">
        <div class="pro-ribbon"><strong>🎯 Espace Professionnel Frenchy Leurres</strong>Retrouvez toutes vos commandes et téléchargez vos factures HT.</div>
        <div class="sec-title">Mes commandes professionnelles</div>
        <div class="side-card">
          <div class="sc-body" id="invoices-container">
            <div class="inv-loading"><div class="spinner"></div><p>Chargement de vos commandes...</p></div>
          </div>
        </div>
      </div>

      <!-- TAB ENTREPRISE -->
      <div class="tab-panel" id="tab-company">
        <div class="sec-title">Mon entreprise</div>
        <div class="side-card">
          <div class="sc-head gold">🏢 Informations professionnelles <button class="btn-fl" onclick="flOpenModal('modalEdit')" style="font-size:10px">✏️ Modifier</button></div>
          <div class="sc-body">
            <div class="info-row"><span class="lbl">Société</span><span class="val">{{ customer.default_address.company | default: '—' }}</span></div>
            <div class="info-row"><span class="lbl">Contact</span><span class="val">{{ customer.first_name }} {{ customer.last_name }}</span></div>
            <div class="info-row"><span class="lbl">Email</span><span class="val" style="font-size:12px">{{ customer.email }}</span></div>
            <div class="info-row"><span class="lbl">Tél.</span><span class="val">{{ customer.default_address.phone | default: '—' }}</span></div>
            <div class="info-row"><span class="lbl">Adresse</span><span class="val" style="font-size:12px;text-align:right">{{ customer.default_address.address1 }}, {{ customer.default_address.zip }} {{ customer.default_address.city }}</span></div>
          </div>
        </div>
      </div>
      {% endif %}

      <!-- TAB ADRESSES -->
      <div class="tab-panel" id="tab-addresses">
        <div class="sec-title">Mes adresses</div>
        {% if customer.addresses.size == 0 %}
          <div class="empty-state"><span class="icon">📍</span><p>Aucune adresse enregistrée.</p></div>
        {% else %}
          {% for address in customer.addresses %}
            <div class="side-card" style="margin-bottom:12px">
              <div class="sc-head">
                {% if address == customer.default_address %}<span class="addr-tag {% if is_pro %}gold{% endif %}">Principale</span>{% else %}<span style="font-size:11px;color:var(--dim)">Adresse {{ forloop.index }}</span>{% endif %}
                <div style="display:flex;gap:8px;align-items:center">
                  <a href="/account/addresses/{{ address.id }}" class="btn-fl" style="font-size:10px">✏️ Modifier</a>
                  {% form 'customer_address', address %}<input type="hidden" name="_method" value="delete"><button type="submit" class="btn-fl danger" style="font-size:10px" onclick="return confirm('Supprimer cette adresse ?')">🗑 Supprimer</button>{% endform %}
                </div>
              </div>
              <div class="sc-body">
                <div class="addr-line"><strong>{{ address.first_name }} {{ address.last_name }}</strong><br>{% if address.company != blank %}{{ address.company }}<br>{% endif %}{{ address.address1 }}<br>{% if address.address2 != blank %}{{ address.address2 }}<br>{% endif %}{{ address.zip }} {{ address.city }}<br>{{ address.country }}</div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
        <a href="/account/addresses/new" class="btn-fl" style="margin-top:8px">+ Ajouter une adresse</a>
      </div>

      <!-- TAB MON COMPTE -->
      <div class="tab-panel" id="tab-account">
        <div class="sec-title">Mon compte</div>
        <div class="side-card">
          <div class="sc-body">
            <div class="info-row"><span class="lbl">Prénom</span><span class="val">{{ customer.first_name }}</span></div>
            <div class="info-row"><span class="lbl">Nom</span><span class="val">{{ customer.last_name }}</span></div>
            <div class="info-row"><span class="lbl">Email</span><span class="val" style="font-size:12px">{{ customer.email }}</span></div>
            <div class="info-row"><span class="lbl">Mot de passe</span><span class="val">••••••••</span></div>
            <div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap">
              <button class="btn-fl" onclick="flOpenModal('modalEdit')">✏️ Modifier</button>
              <button class="btn-fl" onclick="flOpenModal('modalPwd')">🔑 Mot de passe</button>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
      {% if is_pro %}
      <div class="side-card gold-border">
        <div class="sc-head gold">⭐ Statut PRO</div>
        <div class="sc-body">
          <div class="info-row"><span class="lbl">Remise</span><span class="val" style="color:var(--gold)">Remise PRO ✅</span></div>
          <div class="info-row"><span class="lbl">Statut</span><span class="val" style="color:var(--accent2)">✅ Validé</span></div>
          <div class="info-row"><span class="lbl">Commandes</span><span class="val">{{ orders_count }}</span></div>
          <div class="info-row"><span class="lbl">CA total</span><span class="val">{{ total_spent }}</span></div>
        </div>
      </div>
      {% endif %}

      <div class="side-card">
        <div class="sc-head">📍 Adresse principale <a href="/account/addresses" style="color:var(--gold);font-size:10px;text-decoration:none">Gérer</a></div>
        <div class="sc-body">
          {% if customer.default_address %}
            <span class="addr-tag {% if is_pro %}gold{% endif %}">{% if is_pro %}Livraison{% else %}Domicile{% endif %}</span>
            <div class="addr-line"><strong>{{ customer.default_address.first_name }} {{ customer.default_address.last_name }}</strong><br>{% if customer.default_address.company != blank %}{{ customer.default_address.company }}<br>{% endif %}{{ customer.default_address.address1 }}<br>{{ customer.default_address.zip }} {{ customer.default_address.city }}<br>{{ customer.default_address.country }}</div>
          {% else %}<p style="color:var(--dim);font-size:13px">Aucune adresse enregistrée</p>{% endif %}
          <a href="/account/addresses/new" class="btn-fl" style="margin-top:12px">+ Nouvelle adresse</a>
        </div>
      </div>

      <div class="side-card">
        <div class="sc-head">👤 Mon compte <button class="btn-fl" onclick="flOpenModal('modalEdit')" style="font-size:10px">✏️</button></div>
        <div class="sc-body">
          <div class="info-row"><span class="lbl">Prénom</span><span class="val">{{ customer.first_name }}</span></div>
          <div class="info-row"><span class="lbl">Nom</span><span class="val">{{ customer.last_name }}</span></div>
          <div class="info-row"><span class="lbl">Email</span><span class="val" style="font-size:11px">{{ customer.email }}</span></div>
          <div style="margin-top:12px"><button class="btn-fl" onclick="flOpenModal('modalPwd')">🔑 Mot de passe</button></div>
        </div>
      </div>

      <div class="side-card">
        <div class="sc-body" style="text-align:center;padding:14px">
          <a href="{{ routes.account_logout_url }}" class="logout-btn">⏻ Se déconnecter</a>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
var _flIsPro = {{ is_pro | json }};
var _flEmail = {{ customer.email | json }};
var _flFName = {{ customer.first_name | json }};
var _flLName = {{ customer.last_name | json }};
var _flCompany = {{ customer.default_address.company | default: '' | json }};
var _flAddr1 = {{ customer.default_address.address1 | default: '' | json }};
var _flAddrCity = {{ customer.default_address.zip | default: '' | json }} + ' ' + {{ customer.default_address.city | default: '' | json }};
var _flAddrCountry = {{ customer.default_address.country | default: '' | json }};
var _flRecoverPosted = {{ recover_posted | json }};
var _flRecoverErrors = {{ recover_error_count | default: 0 }};

function flTab(name, el) {
  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  var panel = document.getElementById('tab-' + name);
  if (panel) panel.classList.add('active');
  if (el) el.classList.add('active');
}

function flOpenModal(id) {
  var m = document.getElementById(id);
  if (m) { m.classList.add('open'); document.body.style.overflow = 'hidden'; }
}

function flCloseModal(id) {
  var m = document.getElementById(id);
  if (m) { m.classList.remove('open'); document.body.style.overflow = ''; }
}

document.querySelectorAll('.fl-modal-overlay').forEach(function(o) {
  o.addEventListener('click', function(e) { if (e.target === o) flCloseModal(o.id); });
});

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') document.querySelectorAll('.fl-modal-overlay.open').forEach(function(m) { flCloseModal(m.id); });
});

if (_flRecoverPosted === true) {
  flOpenModal('modalPwd');
  document.getElementById('pwdFormWrap').style.display = 'none';
  document.getElementById('pwdSuccess').style.display = 'block';
} else if (_flRecoverErrors > 0) {
  flOpenModal('modalPwd');
}

if (_flIsPro) {
  (function() {
    var c = document.getElementById('invoices-container');
    if (!c) return;
    fetch('https://frenchy-payments.onrender.com/orders?email=' + encodeURIComponent(_flEmail))
      .then(function(r) { if (!r.ok) throw new Error(r.status); return r.json(); })
      .then(function(data) {
        if (!data.orders || data.orders.length === 0) {
          c.innerHTML = '<p style="color:var(--dim);font-size:13px;text-align:center;padding:24px 0">Aucune commande pour le moment.</p>';
          return;
        }
        var html = '';
        data.orders.forEach(function(order) {
          var date = new Date(order.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
          var total = parseFloat(order.total || 0).toFixed(2).replace('.', ',') + ' €';
          var mode = order.payment_mode === 'sepa' ? 'SEPA' : 'CB';
          var sc = 'pending', sl = '⏳ En attente';
          if (order.status === 'captured') { sc = 'paid'; sl = '✅ Payé'; }
          else if (order.status === 'authorized_pending_capture' || order.status === 'scheduled') { sc = 'scheduled'; sl = '🕐 Différé'; }
          else if (order.status === 'error') { sc = 'error'; sl = '❌ Erreur'; }
          var desc = '';
          try {
            var items = typeof order.items_json === 'string' ? JSON.parse(order.items_json) : order.items_json;
            if (Array.isArray(items) && items.length) {
              var n = items.slice(0, 2).map(function(i) { return i.title || ''; }).filter(Boolean);
              desc = n.join(' · ');
              if (items.length > 2) desc += ' +' + (items.length - 2);
            }
          } catch(e) {}
          var oId = order.id;
          var invNum = 'FL-' + String(oId).padStart(4, '0');
          html += '<div class="invoice-row">';
          html += '<div style="flex:1;min-width:120px;"><div class="inv-ref">' + invNum + '</div>';
          html += '<div class="inv-date">' + date + ' · ' + mode + '</div>';
          if (desc) html += '<div class="inv-items">' + desc + '</div>';
          html += '</div>';
          html += '<span class="inv-status ' + sc + '">' + sl + '</span>';
          html += '<div class="inv-amount">' + total + ' HT</div>';
          html += '<button class="btn-pdf" onclick="flPDF(' + oId + ')">⬇ Facture PDF</button>';
          html += '</div>';
        });
        c.innerHTML = html;
        window._flOrders = data.orders;
      })
      .catch(function() {
        c.innerHTML = '<p style="color:var(--red);font-size:13px;text-align:center;padding:24px 0">❌ Impossible de charger les commandes.</p>';
      });
  })();
}

function flPDF(orderId) {
  if (!window._flOrders) return;
  var order = window._flOrders.find(function(o) { return o.id == orderId; });
  if (!order) return;

  var items = typeof order.items_json === 'string' ? JSON.parse(order.items_json) : order.items_json;
  var date = new Date(order.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
  var dueDate = new Date(order.due_at).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
  var invNum = 'FL-' + String(order.id).padStart(4, '0');
  var mode = order.payment_mode === 'sepa' ? 'Prélèvement SEPA' : 'Carte bancaire';
  var delays = { 0: 'Comptant', 7: '1 semaine', 14: '2 semaines', 21: '3 semaines', 28: '4 semaines' };
  var delayLabel = delays[order.delay_days] || (order.delay_days + ' jours');

  var subTotal = parseFloat(order.total || 0);
  var shipping = 0, shippingNote = '';
  if (subTotal >= 150) { shipping = 0; shippingNote = 'Offerts (≥ 150 € HT)'; }
  else {
    var grams = 0;
    items.forEach(function(item) {
      var v = item.variant || '';
      var m = v.match(/(\d+[\.,]?\d*)\s*gr?/i);
      if (m) grams += parseFloat(m[1].replace(',', '.')) * item.quantity;
      else grams += 50 * item.quantity;
    });
    if (grams <= 100) { shipping = 2.90; shippingNote = '0–100 g'; }
    else if (grams <= 250) { shipping = 4.50; shippingNote = '100–250 g'; }
    else if (grams <= 500) { shipping = 6.90; shippingNote = '250–500 g'; }
    else if (grams <= 1000) { shipping = 8.90; shippingNote = '500 g–1 kg'; }
    else if (grams <= 5000) { shipping = 14.00; shippingNote = '1–5 kg'; }
    else { shipping = 25.00; shippingNote = '+5 kg'; }
  }

  var grandTotal = (subTotal + shipping).toFixed(2).replace('.', ',');
  var subTotalStr = subTotal.toFixed(2).replace('.', ',');
  var shippingStr = shipping === 0 ? 'Offerts' : shipping.toFixed(2).replace('.', ',') + ' €';

  var rows = '';
  items.forEach(function(item, i) {
    var bg = i % 2 === 0 ? '#fff' : '#f9f9f9';
    var ref = item.sku || '—';
    var name = (item.title || '').split('|')[0].trim();
    var variant = item.variant || '';
    var grammage = '—', couleur = '—', pack = '—';
    variant.split('/').forEach(function(p) {
      p = p.trim();
      if (/\d+[\.,]?\d*\s*gr?/i.test(p)) grammage = p;
      else if (/^x\d+/i.test(p)) pack = p;
      else if (p.length > 1 && !/^\d+\s*cm/i.test(p)) couleur = p;
    });
    var qty = item.quantity || 1;
    var pu = parseFloat(item.unit_price || 0).toFixed(2).replace('.', ',');
    var lt = parseFloat(item.line_price || 0).toFixed(2).replace('.', ',');
    var pvc = (parseFloat(item.unit_price || 0) * 2.5).toFixed(2).replace('.', ',');
    rows += '<tr style="background:' + bg + ';">';
    rows += '<td style="padding:7px 5px;color:#c8141e;font-weight:700;font-size:10px;white-space:nowrap;">' + ref + '</td>';
    rows += '<td style="padding:7px 5px;font-weight:600;font-size:10px;max-width:150px;">' + name + '</td>';
    rows += '<td style="padding:7px 5px;text-align:center;font-size:10px;color:#555;">' + grammage + '</td>';
    rows += '<td style="padding:7px 5px;font-size:10px;color:#555;max-width:80px;">' + couleur + '</td>';
    rows += '<td style="padding:7px 5px;text-align:center;font-size:10px;color:#555;">' + pack + '</td>';
    rows += '<td style="padding:7px 5px;text-align:center;font-weight:700;font-size:10px;">' + qty + '</td>';
    rows += '<td style="padding:7px 5px;text-align:right;font-size:10px;">' + pu + ' €</td>';
    rows += '<td style="padding:7px 5px;text-align:right;font-weight:700;font-size:10px;">' + lt + ' €</td>';
    rows += '<td style="padding:7px 5px;text-align:right;font-size:10px;color:#888;">' + pvc + ' €</td>';
    rows += '</tr>';
  });

  var cName = _flFName + ' ' + _flLName;
  var company = _flCompany || cName;

  var html = '<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Facture ' + invNum + ' — Frenchy Leurres</title>';
  html += '<style>*{box-sizing:border-box;}body{font-family:Arial,sans-serif;font-size:12px;color:#222;margin:0;padding:16px;max-width:900px;margin:0 auto;}@media print{.no-print{display:none!important;}body{padding:0;}}table{border-collapse:collapse;width:100%;}p{margin:0;}</style>';
  html += '</head><body>';
  html += '<div class="no-print" style="text-align:right;margin-bottom:12px;"><button onclick="window.print()" style="background:#c8141e;color:#fff;border:none;padding:10px 20px;border-radius:6px;font-size:13px;font-weight:700;cursor:pointer;letter-spacing:1px;">🖨️ IMPRIMER / TÉLÉCHARGER PDF</button></div>';

  html += '<div style="border:1px solid #ddd;border-radius:8px;overflow:hidden;">';
  html += '<div style="background:#c8141e;height:5px;"></div>';

  html += '<div style="padding:16px 22px;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">';
  html += '<div style="display:flex;align-items:center;gap:12px;">';
  html += '<img src="https://cdn.shopify.com/s/files/1/0831/2157/0124/files/Image13251.jpg?v=1773837209" style="width:50px;height:50px;border-radius:50%;object-fit:cover;border:2px solid #c8141e;">';
  html += '<div><div style="font-size:15px;font-weight:700;letter-spacing:2px;color:#111;">FRENCHY LEURRES</div>';
  html += '<div style="font-size:10px;color:#666;line-height:1.7;">GAUTIER JOHAN – FRENCHY LEURRES<br>Domaine St Jean, 8 Chemin de campagne roque<br>13110 Port-de-Bouc, France<br>gautierfishing@gmail.com<br>SIRET : 48359538500038 · TVA : FR 0L483595385</div></div></div>';
  html += '<div style="text-align:right;"><div style="font-size:20px;font-weight:700;color:#c8141e;">FACTURE</div>';
  html += '<div style="font-size:13px;font-weight:700;color:#111;margin-top:3px;">N° ' + invNum + '</div>';
  html += '<div style="font-size:10px;color:#666;">Date : ' + date + '</div>';
  html += '<div style="font-size:10px;color:#666;">Échéance : ' + dueDate + '</div></div></div>';

  html += '<div style="padding:12px 22px;display:grid;grid-template-columns:1fr 1fr;gap:16px;border-bottom:1px solid #eee;background:#fafafa;">';
  html += '<div><div style="font-size:9px;font-weight:700;color:#888;letter-spacing:2px;text-transform:uppercase;margin-bottom:5px;">Émetteur</div>';
  html += '<div style="font-size:11px;font-weight:700;">Frenchy Leurres — Johan Gautier</div>';
  html += '<div style="font-size:10px;color:#555;line-height:1.7;">Domaine St Jean, 8 Chemin de campagne roque<br>13110 Port-de-Bouc, France<br>gautierfishing@gmail.com</div></div>';
  html += '<div><div style="font-size:9px;font-weight:700;color:#888;letter-spacing:2px;text-transform:uppercase;margin-bottom:5px;">Facturé à</div>';
  html += '<div style="font-size:11px;font-weight:700;">' + company + '</div>';
  html += '<div style="font-size:10px;color:#555;line-height:1.7;">' + cName + '<br>' + _flEmail;
  if (_flAddr1) html += '<br>' + _flAddr1 + '<br>' + _flAddrCity + '<br>' + _flAddrCountry;
  html += '<br>Règlement : ' + mode + ' · ' + delayLabel + '</div></div></div>';

  html += '<div style="padding:14px 22px;"><table><thead><tr style="background:#c8141e;">';
  ['Référence','Désignation','Grammage','Couleur','Pack','Qté','PU HT','Total HT','PVC'].forEach(function(h, i) {
    var a = ['left','left','center','left','center','center','right','right','right'][i];
    html += '<th style="padding:7px 5px;color:#fff;font-size:9px;text-transform:uppercase;text-align:' + a + ';">' + h + '</th>';
  });
  html += '</tr></thead><tbody>' + rows + '</tbody></table>';

  html += '<div style="display:flex;justify-content:flex-end;margin-top:12px;"><div style="width:230px;font-size:11px;">';
  html += '<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid #eee;"><span style="color:#666;">Sous-total HT</span><span>' + subTotalStr + ' €</span></div>';
  html += '<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid #eee;"><span style="color:#666;">Frais de port (' + shippingNote + ')</span><span>' + shippingStr + '</span></div>';
  html += '<div style="display:flex;justify-content:space-between;padding:7px 0;font-size:14px;font-weight:700;border-top:2px solid #c8141e;margin-top:2px;"><span>TOTAL HT</span><span style="color:#c8141e;">' + grandTotal + ' €</span></div>';
  html += '</div></div></div>';

  html += '<div style="margin:0 22px 14px;padding:9px 13px;background:#fff8f8;border:1px solid rgba(200,20,30,0.15);border-radius:6px;font-size:10px;color:#555;line-height:1.8;">';
  html += '<strong style="color:#111;">Règlement :</strong> ' + mode + ' — ' + delayLabel + ' · Échéance le ' + dueDate + '<br>';
  html += '<strong style="color:#111;">Frais de port :</strong> Offerts ≥ 150 € HT · Barème : 0-100g : 2,90€ · 100-250g : 4,50€ · 250-500g : 6,90€ · 500g-1kg : 8,90€ · 1-5kg : 14,00€ · +5kg : 25,00€</div>';

  html += '<div style="padding:10px 22px;border-top:1px solid #eee;text-align:center;font-size:9px;color:#888;line-height:1.8;">';
  html += 'Frenchy Leurres · GAUTIER JOHAN · Domaine St Jean, 8 Chemin de campagne roque · 13110 Port-de-Bouc<br>';
  html += 'SIRET : 48359538500038 · N° TVA intracommunautaire : FR 0L483595385<br>';
  html += 'Auto-entrepreneur non assujetti à la TVA — Article 293B du CGI<br>';
  html += 'Tout litige doit être signalé dans les 8 jours suivant la réception de la commande.</div>';
  html += '</div></body></html>';

  var w = window.open('', '_blank', 'width=920,height=720,scrollbars=yes');
  if (w) { w.document.write(html); w.document.close(); }
}
</script>
